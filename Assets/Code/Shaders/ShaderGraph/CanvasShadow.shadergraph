{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "634adebeee6a421287a1367e500ab200",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GaussianBlur (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -773.0,
            "y": 222.99996948242188,
            "width": 228.00006103515626,
            "height": 173.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "8ff911ffdd084b5aa1eb09f36ca435b3"
        },
        {
            "m_Id": "8f7193d4a6314384aba174729fd41068"
        },
        {
            "m_Id": "cd647425c4f1401ba2f1600b670f71cd"
        },
        {
            "m_Id": "d0ec16643b4c491098eeb2bc52966576"
        },
        {
            "m_Id": "64ba7ae42e90448293351e77c62d4be0"
        },
        {
            "m_Id": "ee685afcceb141018dae8912021511e5"
        },
        {
            "m_Id": "490a8ed62e33419da5ad7634a93b4912"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GaussianBlur",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float4 col = float4(0.0, 0.0, 0.0, 0.0);\r\nfloat kernelSum = 0.0;\n\rint upper = ((Blur - 1) / 2);\r\nint lower = -upper;\r\n\r\nfor (int x = lower; x <= upper; ++x)\r\n{\r\n\tfor (int y = lower; y <= upper; ++y)\r\n\t\t{\r\n\t\t\tkernelSum++;\r\n\r\n\t\t\tfloat2 offset = float2(Texture_TexelSize.x * x, Texture_TexelSize.y * y);\r\n\t\t\tcol += Texture.Sample(Sampler, UV + offset);\r\n\t\t}\r}\r\n\ncol /= kernelSum;\r\n\nOut_RGB = float3(col.r, col.g, col.b);\r\nOut_Alpha = col.a;"
}

